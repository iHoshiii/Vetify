// Prisma Schema — Single source of truth for database configuration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Pet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  species   String
  breed     String?
  age       Int?
  weight    Float?
  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  pets      Pet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
